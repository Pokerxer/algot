[Unit]
Description=ICT V6 Trading Bot
After=network.target

[Service]
Type=simple
User=%u
WorkingDirectory=%h/algot
ExecStart=/usr/bin/python3 %h/algot/ict_v6_ibkr.py --symbols "BTCUSD,ETHUSD,GC,CL" --mode paper --port 7497
Restart=always
RestartSec=10

StandardOutput=append:%h/algot/v6_trading.log
StandardError=append:%h/algot/v6_trading.log

[Install]
WantedBy=multi-user.target
